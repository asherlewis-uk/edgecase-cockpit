+    const onSend = vi.fn();
+    const user = userEvent.setup();
+    render(<ChatInput {...defaultProps} input="Hello" onSend={onSend} />);
+
+    await user.click(screen.getByLabelText("Send"));
+    expect(onSend).toHaveBeenCalledTimes(1);
