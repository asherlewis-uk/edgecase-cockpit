+  breatheMs: 2000,
+  bright: 1,
+  mid: 0.6,
+  glow: 0.4,
+};
+
+const defaultProps = {
+  input: "",
+  setInput: vi.fn(),
+  attachments: [] as DraftAttachment[],
+  setAttachments: vi.fn(),
+  fileInputRef: { current: null },
+  recording: "idle" as const,
+  onSend: vi.fn(),
+  onCaptureScreenshot: vi.fn(),
+  onStartRecording: vi.fn(),
+  onStopRecording: vi.fn(),
+  onCancelTranscribing: vi.fn(),
+  onIngestFiles: vi.fn(),
