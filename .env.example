# =============================================================================
# Edgecase Cockpit — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.
#
# Required: SESSION_SECRET
# Optional: everything else (features degrade gracefully without them)

# ---- Core ----

# ---- Native App API URL ----
# Deployed Cloudflare Worker URL for native app API calls.
# Native shells (Electron, Capacitor) cannot use same-origin /api/* paths.
# Set this to your Worker URL so native apps can reach the server.
# Example: https://edgecase-cockpit.asher-lewis-knight.workers.dev
VITE_NATIVE_API_URL=https://edgecase-cockpit.asher-lewis-knight.workers.dev

SESSION_SECRET=change-me-to-a-random-string
RATE_LIMIT_BACKEND=cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=

# ---- Live Provider Tests (optional) ----
# Set RUN_LIVE_PROVIDER_TESTS=true to run live provider tests.
# Requires at least one API key below.
RUN_LIVE_PROVIDER_TESTS=
STRICT_LIVE_PROVIDER_TESTS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- Java / Android SDK ----
# Paths to the Java 21 JDK and Android SDK.
# macOS Homebrew + Android Studio defaults shown.
JAVA_HOME=/opt/homebrew/Cellar/openjdk@21/21.0.11/libexec/openjdk.jdk/Contents/Home
ANDROID_HOME=$HOME/Library/Android/sdk
ANDROID_SDK_ROOT=$HOME/Library/Android/sdk

# ---- macOS Signing & Notarization ----
# Required for a signed, notarized macOS DMG.
# APPLE_ID is your Apple Developer account email.
# APPLE_TEAM_ID is the 10-character team ID from developer.apple.com.
# APPLE_APP_SPECIFIC_PASSWORD is generated at appleid.apple.com.
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_SPECIFIC_PASSWORD=

# CSC_LINK is a path to a .p12 Developer ID Application certificate.
# CSC_KEY_PASSWORD is the password for that certificate.
CSC_LINK=
CSC_KEY_PASSWORD=

# ---- iOS Signing ----
# Must match the App ID registered in your Apple Developer account.
IOS_BUNDLE_ID=uk.asherlewis.edgecase.cockpit

# ---- Android Release Signing ----
# Path to your release keystore (.keystore or .jks).
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
